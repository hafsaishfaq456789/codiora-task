
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Student Portal - CODIORA</title>
<style>
:root {
  --primary: #4f46e5;
  --primary-dark: #3730a3;
  --dark: #1e293b;
  --success: #16a34a;
  --danger: #dc2626;
}
* { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
body { background: #f1f5f9; }

.auth-page { display: none; justify-content: center; align-items: center; min-height: 100vh; padding: 2rem 1rem; }
.auth-page.active { display: flex; }
.login-box { background: white; padding: 2.5rem; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); width: 100%; max-width: 400px; animation: fadeInUp 0.4s ease; }
.login-box h2 { text-align: center; margin-bottom: 0.5rem; color: var(--dark); }
.login-box .subtitle { text-align: center; color: #64748b; font-size: 0.85rem; margin-bottom: 1.5rem; }
.login-box input { width: 100%; padding: 0.8rem; margin-bottom: 1rem; border: 2px solid #cbd5e1; border-radius: 6px; transition: border-color 0.2s; }
.login-box input:focus { outline: none; border-color: var(--primary); }
.error { color: var(--danger); font-size: 0.9rem; margin-top: -0.5rem; margin-bottom: 1rem; display: none; }
.success-text { color: var(--success); font-size: 0.9rem; margin-top: -0.5rem; margin-bottom: 1rem; display: none; }
.auth-links { display: flex; justify-content: space-between; margin-top: 1rem; font-size: 0.85rem; }
.auth-links a { color: var(--primary); text-decoration: none; cursor: pointer; }
.auth-links a:hover { text-decoration: underline; }

#app { display: none; }

.navbar {
  background: var(--dark); color: white; display: flex; justify-content: space-between;
  align-items: center; padding: 1rem 5%; position: sticky; top: 0; z-index: 10;
}
.logo { font-weight: bold; color: #a5b4fc; font-size:1.2rem }
.nav-links { display: flex; list-style: none; gap: 1.5rem; align-items: center; }
.nav-links a { color: white; text-decoration: none; cursor: pointer; padding: 0.5rem; border-radius: 6px; transition: background 0.2s; }
.nav-links a:hover { background: rgba(255,255,255,0.1); }
.nav-links a.active { background: var(--primary); border-radius:6px; }
.btn-logout { background: var(--danger); padding: 0.5rem 1rem; border-radius: 6px; }
.btn-logout:hover { background: #b91c1c !important; }
.menu-toggle { display: none; font-size: 1.8rem; cursor: pointer; }
.welcome-user { color: #a5b4fc; font-size: 0.85rem; margin-right: 0.5rem; }

.page { display: none; padding: 3rem 5%; min-height: 70vh; }
.page.active { display: block; animation: fadeInUp 0.35s ease; }
h2 { border-left:4px solid var(--primary); padding-left:10px; margin-bottom:1rem; }

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes popIn {
  from { opacity: 0; transform: scale(0.92); }
  to { opacity: 1; transform: scale(1); }
}

.stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; margin: 2rem 0; }
.card { background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); text-align: center; border-top: 4px solid var(--primary); transition: transform 0.2s, box-shadow 0.2s; animation: popIn 0.35s ease backwards; }
.card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.12); }
.card h3 { color: #64748b; font-size: 0.9rem; }
.card p { font-size: 2rem; font-weight: bold; margin-top:0.5rem; }

.table-controls { display: flex; gap: 1rem; margin: 1.5rem 0; flex-wrap: wrap; }
.table-controls input,.table-controls select { padding: 0.7rem; border: 2px solid #cbd5e1; border-radius: 6px; }
.table-controls input:focus,.table-controls select:focus { outline: none; border-color: var(--primary); }
.table-wrapper { overflow-x: auto; margin-top:1rem; }
table { width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; }
th, td { padding: 1rem; text-align: left; border-bottom: 1px solid #e2e8f0; }
th { background: var(--primary); color: white; cursor: pointer; user-select: none; }
th:hover { background: #3730a3; }
tbody tr { cursor: pointer; transition: background 0.15s; }
tbody tr:hover { background: #eef2ff; }
.status-pass { color: var(--success); font-weight: 600; }
.status-fail { color: var(--danger); font-weight: 600; }
.no-results { text-align: center; padding: 2rem; color: #94a3b8; }

.form-box { background: white; padding: 2rem; border-radius: 12px; max-width: 600px; margin:2rem auto; }
.form-box input,.form-box select { width: 100%; padding: 0.8rem; margin-bottom: 1rem; border: 2px solid #cbd5e1; border-radius: 6px; transition: border-color 0.2s; }
.form-box input:focus,.form-box select:focus { outline: none; border-color: var(--primary); }
.btn { background: var(--primary); color: white; padding: 0.8rem 1.5rem; border: none; border-radius: 6px; cursor: pointer; font-weight:600; transition: background 0.2s, transform 0.1s; }
.btn:hover { background: var(--primary-dark); }
.btn:active { transform: scale(0.98); }
.btn-outline { background: white; color: var(--primary); border: 2px solid var(--primary); padding: 0.7rem 1.4rem; border-radius: 6px; cursor: pointer; font-weight: 600; }
.btn-outline:hover { background: #eef2ff; }
#successMsg { color: var(--success); margin-top:1rem; display:none; font-weight:600; }

.perf-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.2rem; margin-top: 1.5rem; }
.perf-card { background: white; border-radius: 12px; padding: 1.3rem; box-shadow: 0 4px 6px rgba(0,0,0,0.08); cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; animation: popIn 0.35s ease backwards; border-left: 5px solid var(--primary); }
.perf-card:hover { transform: translateY(-4px); box-shadow: 0 12px 20px rgba(0,0,0,0.12); }
.perf-card .pname { font-weight: 700; color: var(--dark); font-size: 1.05rem; }
.perf-card .psub { color: #64748b; font-size: 0.8rem; margin: 0.2rem 0 0.8rem; }
.perf-bar-track { background: #e2e8f0; border-radius: 20px; height: 10px; overflow: hidden; }
.perf-bar-fill { height: 100%; border-radius: 20px; width: 0%; transition: width 0.8s ease; }
.perf-score-row { display: flex; justify-content: space-between; align-items: center; margin-top: 0.5rem; font-size: 0.85rem; }


.profile-card { background: white; border-radius: 16px; max-width: 520px; margin: 2rem auto; padding: 2.5rem; text-align: center; box-shadow: 0 10px 25px rgba(0,0,0,0.1); animation: popIn 0.4s ease; }
.profile-avatar { width: 90px; height: 90px; border-radius: 50%; background: var(--primary); color: white; font-size: 2rem; font-weight: 700; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; }
.profile-card h3 { font-size: 1.4rem; color: var(--dark); }
.profile-card .pid { color: #64748b; font-size: 0.9rem; margin-bottom: 1.5rem; }
.profile-detail-row { display: flex; justify-content: space-between; padding: 0.7rem 0; border-bottom: 1px solid #e2e8f0; text-align: left; }
.profile-detail-row span:first-child { color: #64748b; }
.profile-detail-row span:last-child { font-weight: 600; color: var(--dark); }
.profile-bar-wrap { margin: 1.5rem 0; }
.profile-status-badge { display: inline-block; padding: 0.4rem 1rem; border-radius: 20px; font-weight: 700; margin-top: 1rem; }
.badge-pass { background: #dcfce7; color: var(--success); }
.badge-fail { background: #fee2e2; color: var(--danger); }
.empty-state { text-align: center; padding: 3rem; color: #94a3b8; }

footer { background: var(--dark); color: #cbd5e1; text-align: center; padding: 2rem; margin-top: 3rem; }

@media (max-width: 768px) {
 .nav-links { display: none; flex-direction: column; position: absolute; top: 60px; left: 0; width: 100%; background: var(--dark); padding: 1rem 0; }
 .nav-links.show { display: flex; }
 .menu-toggle { display: block; }
 .stats { grid-template-columns: 1fr; }
 .table-controls { flex-direction: column; }
 .perf-grid { grid-template-columns: 1fr 1fr; }
 .welcome-user { display: none; }
}
@media (max-width: 480px) {
 .perf-grid { grid-template-columns: 1fr; }
 .profile-card { padding: 1.5rem; }
}
</style>
</head>
<body>


<section id="loginPage" class="auth-page active">
  <div class="login-box">
    <h2>CODIORA Portal Login</h2>
    <p class="subtitle">Sign in to continue</p>
    <form onsubmit="return loginUser(event)">
      <input type="text" id="username" placeholder="Username *" required>
      <input type="password" id="password" placeholder="Password *" required>
      <p class="error" id="loginError">Invalid Username or Password</p>
      <button class="btn" style="width:100%;">Login</button>
      <p style="text-align:center; margin-top:1rem; font-size:0.85rem; color:#64748b;">Demo: Admin / 1234</p>
      <div class="auth-links">
        <a onclick="showAuthPage('registerPage')">Create account</a>
        <a onclick="showAuthPage('forgotPage')">Forgot password?</a>
      </div>
    </form>
  </div>
</section>

<section id="registerPage" class="auth-page">
  <div class="login-box">
    <h2>Create Account</h2>
    <p class="subtitle">Register a new CODIORA account</p>
    <form onsubmit="return registerUser(event)">
      <input type="text" id="regUsername" placeholder="Choose Username *" required minlength="3">
      <input type="email" id="regEmail" placeholder="Email *" required>
      <input type="password" id="regPassword" placeholder="Password (min 4 chars) *" required minlength="4">
      <input type="password" id="regConfirm" placeholder="Confirm Password *" required>
      <p class="error" id="registerError"></p>
      <button class="btn" style="width:100%;">Register</button>
      <div class="auth-links">
        <a onclick="showAuthPage('loginPage')">&larr; Back to Login</a>
      </div>
    </form>
  </div>
</section>

<section id="forgotPage" class="auth-page">
  <div class="login-box">
    <h2>Forgot Password</h2>
    <p class="subtitle">Enter your username to reset your password (simulated)</p>
    <form onsubmit="return sendResetCode(event)">
      <input type="text" id="forgotUsername" placeholder="Username *" required>
      <p class="error" id="forgotError"></p>
      <button class="btn" style="width:100%;">Send Reset Code</button>
      <div class="auth-links">
        <a onclick="showAuthPage('loginPage')">&larr; Back to Login</a>
      </div>
    </form>
  </div>
</section>


<section id="resetPage" class="auth-page">
  <div class="login-box">
    <h2>Reset Password</h2>
    <p class="subtitle" id="resetSubtitle">Enter a new password for your account</p>
    <form onsubmit="return resetPassword(event)">
      <input type="text" id="resetUsername" placeholder="Username" readonly>
      <input type="password" id="resetNewPassword" placeholder="New Password *" required minlength="4">
      <input type="password" id="resetConfirmPassword" placeholder="Confirm New Password *" required>
      <p class="error" id="resetError"></p>
      <button class="btn" style="width:100%;">Update Password</button>
