<script>
const STUDENTS_KEY = 'codiora_students';
const USERS_KEY = 'codiora_users';
const SESSION_KEY = 'codiora_currentUser';

let studentsData = [];
let users = [];
let currentUser = null;
let resetTargetUser = null;

function loadData(){
  let storedStudents = localStorage.getItem(STUDENTS_KEY);
  if(storedStudents){
    studentsData = JSON.parse(storedStudents);
  } else {
    studentsData = [
      {id: "001", name: "Ali Khan", subject: "Math", score: 88},
      {id: "002", name: "Sara Ahmed", subject: "Science", score: 92},
      {id: "003", name: "Usman Malik", subject: "English", score: 67},
      {id: "004", name: "Ayesha", subject: "Math", score: 45}
    ];
    saveStudents();
  }

  let storedUsers = localStorage.getItem(USERS_KEY);
  if(storedUsers){
    users = JSON.parse(storedUsers);
  } else {
    users = [ {username: "Admin", email: "admin@codiora.com", password: "1234"} ];
    saveUsers();
  }
}

function saveStudents(){ localStorage.setItem(STUDENTS_KEY, JSON.stringify(studentsData)); }
function saveUsers(){ localStorage.setItem(USERS_KEY, JSON.stringify(users)); }

function showAuthPage(id){
  document.querySelectorAll('.auth-page').forEach(p => p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
 
  document.querySelectorAll('.auth-page .error').forEach(e => { e.style.display = 'none'; e.innerText = ''; });
}

function loginUser(e){
  e.preventDefault();
  let user = document.getElementById('username').value.trim();
  let pass = document.getElementById('password').value;
  let found = users.find(u => u.username === user && u.password === pass);

  if(found){
    currentUser = found.username;
    sessionStorage.setItem(SESSION_KEY, currentUser);
    document.getElementById('loginError').style.display = 'none';
    document.getElementById('loginPage').classList.remove('active');
    document.getElementById('app').style.display = 'block';
    document.getElementById('welcomeUser').innerText = 'Hi, ' + currentUser;
    renderTable();
    updateAllStats();
  } else {
    document.getElementById('loginError').style.display = 'block';
  }
  return false;
}

function registerUser(e){
  e.preventDefault();
  let uname = document.getElementById('regUsername').value.trim();
  let email = document.getElementById('regEmail').value.trim();
  let pass = document.getElementById('regPassword').value;
  let confirm = document.getElementById('regConfirm').value;
  let errEl = document.getElementById('registerError');

  if(users.some(u => u.username.toLowerCase() === uname.toLowerCase())){
    errEl.innerText = 'Username already taken'; errEl.style.display = 'block'; return false;
  }
  if(pass !== confirm){
    errEl.innerText = 'Passwords do not match'; errEl.style.display = 'block'; return false;
  }

  users.push({username: uname, email, password: pass});
  saveUsers();
  errEl.style.display = 'none';
  e.target.reset();
  alert('Account created! You can now log in.');
  showAuthPage('loginPage');
  return false;
}

function sendResetCode(e){
  e.preventDefault();
  let uname = document.getElementById('forgotUsername').value.trim();
  let errEl = document.getElementById('forgotError');
  let found = users.find(u => u.username.toLowerCase() === uname.toLowerCase());

  if(!found){
    errEl.innerText = 'No account found with that username'; errEl.style.display = 'block'; return false;
  }

  errEl.style.display = 'none';
  resetTargetUser = found.username;
  document.getElementById('resetUsername').value = found.username;
  document.getElementById('resetSubtitle').innerText = 'Reset code "sent" (simulated) — set your new password below';
  showAuthPage('resetPage');
  return false;
}

function resetPassword(e){
  e.preventDefault();
  let newPass = document.getElementById('resetNewPassword').value;
  let confirmPass = document.getElementById('resetConfirmPassword').value;
  let errEl = document.getElementById('resetError');

  if(newPass !== confirmPass){
    errEl.innerText = 'Passwords do not match'; errEl.style.display = 'block'; return false;
  }

  let user = users.find(u => u.username === resetTargetUser);
  if(user){
    user.password = newPass;
    saveUsers();
    errEl.style.display = 'none';
    alert('Password updated! Please log in with your new password.');
    e.target.reset();
    showAuthPage('loginPage');
  }
  return false;
}

function logout(){
  currentUser = null;
  sessionStorage.removeItem(SESSION_KEY);
  document.getElementById('app').style.display = 'none';
  showAuthPage('loginPage');
  document.getElementById('username').value = '';
  document.getElementById('password').value = '';
}

function openPage(id, event){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.querySelectorAll('.nav-links a').forEach(a=>a.classList.remove('active'));
  if(event && event.target) event.target.classList.add('active');
  window.scrollTo(0,0);
  document.getElementById('navLinks').classList.remove('show');
  if(id === 'home' || id === 'dashboard'){
    updateAllStats();
    renderTable();
  }
}

function menuOpen(){
  document.getElementById('navLinks').classList.toggle('show');
}

function scoreColor(score){
  if(score >= 80) return '#16a34a';
  if(score >= 50) return '#4f46e5';
  return '#dc2626';
}

function renderPerformanceCards(containerId, data){
  let container = document.getElementById(containerId);
  if(!container) return;
  container.innerHTML = '';
  data.forEach((s, i) => {
    let color = scoreColor(s.score);
    let card = document.createElement('div');
    card.className = 'perf-card';
    card.style.animationDelay = (i * 0.05) + 's';
    card.style.borderLeftColor = color;
    card.onclick = () => viewProfile(s.id);
    card.innerHTML = `
      <div class="pname">${s.name}</div>
      <div class="psub">${s.subject} &bull; ID ${s.id}</div>
      <div class="perf-bar-track"><div class="perf-bar-fill" style="background:${color};" data-target="${s.score}"></div></div>
      <div class="perf-score-row"><span>Score</span><strong style="color:${color}">${s.score}%</strong></div>
    `;
    container.appendChild(card);
  });
 
  requestAnimationFrame(() => {
    container.querySelectorAll('.perf-bar-fill').forEach(bar => {
      let target = bar.getAttribute('data-target');
      setTimeout(()=>{ bar.style.width = target + '%'; }, 30);
    });
  });
}

function updateAllStats(){
  let total = studentsData.length;
  let passCount = studentsData.filter(s => s.score >= 50).length;
  let avg = total > 0? Math.round(studentsData.reduce((a,b) => a + b.score, 0) / total) : 0;
  let scores = studentsData.map(s => s.score);
  let highest = total > 0? Math.max(...scores) : 0;
  let lowest = total > 0? Math.min(...scores) : 0;

  let subjCount = {};
  studentsData.forEach(s => subjCount[s.subject] = (subjCount[s.subject]||0)+1);
  let topSubj = Object.keys(subjCount).length ? Object.keys(subjCount).reduce((a,b) => subjCount[a] > subjCount[b]? a : b) : "-";

  document.getElementById('totalStudents').innerText = total;
  document.getElementById('avgScore').innerText = avg + '%';
  document.getElementById('passRate').innerText = total > 0? Math.round((passCount/total)*100) + '%' : '0%';
  document.getElementById('topSubject').innerText = topSubj;

  document.getElementById('testsDone').innerText = total;
  document.getElementById('highestScore').innerText = highest + '%';
  document.getElementById('lowestScore').innerText = lowest + '%';
  document.getElementById('totalCard').innerText = total;

  renderPerformanceCards('perfGridHome', studentsData);
  renderPerformanceCards('perfGridDashboard', studentsData);
}

function addStu(e){
  e.preventDefault();

  let name = document.getElementById('sname').value.trim();
  let id = document.getElementById('sid').value.trim();
  let subject = document.getElementById('ssub').value;
  let score = parseInt(document.getElementById('sscore').value);

  if(name.length < 3){ alert("Name must be 3+ characters"); return false; }
  if(studentsData.some(s => s.id === id)){ alert("Student ID already exists"); return false; }
  if(score < 0 || score > 100){ alert("Score must be 0-100"); return false; }

  studentsData.push({id, name, subject, score});
  saveStudents();

  renderTable();
  updateAllStats();

  document.getElementById('successMsg').style.display = 'block';
  setTimeout(()=>{ document.getElementById('successMsg').style.display = 'none'; }, 3000);
  e.target.reset();
  return false;
}

function renderTable(){
  renderFilteredTable(studentsData);
}

function rowHTML(s){
  let status = s.score >= 50? 'Pass' : 'Fail';
  let statusClass = s.score >= 50? 'status-pass' : 'status-fail';
  return `<tr onclick="viewProfile('${s.id}')"><td>${s.id}</td><td>${s.name}</td><td>${s.subject}</td><td>${s.score}</td><td class="${statusClass}">${status}</td></tr>`;
}

function renderFilteredTable(data){
  let tbody = document.querySelector('#studentTable tbody');
  tbody.innerHTML = '';
  if(data.length === 0){
    tbody.innerHTML = '<tr><td colspan="5" class="no-results">No matching students found</td></tr>';
    return;
  }
  data.forEach(s => { tbody.innerHTML += rowHTML(s); });
}

function filterTable(){
  let search = document.getElementById('searchInput').value.toLowerCase();
  let subject = document.getElementById('filterSubject').value;
  let status = document.getElementById('filterStatus').value;

  let filtered = studentsData.filter(s => {
    let matchesSearch = s.name.toLowerCase().includes(search) || s.id.toLowerCase().includes(search);
    let matchesSubject = subject === "" || s.subject === subject;
    let matchesStatus = status === "" || (status === "pass" && s.score >= 50) || (status === "fail" && s.score < 50);
    return matchesSearch && matchesSubject && matchesStatus;
  });
  renderFilteredTable(filtered);
}

function sortTable(){
  let order = document.getElementById('sortScore').value;
  if(order === "asc") studentsData.sort((a,b) => a.score - b.score);
  if(order === "desc") studentsData.sort((a,b) => b.score - a.score);
  saveStudents();
  filterTable();
}

function sortByColumn(colIndex){
  studentsData.sort((a,b) => {
    let valA = colIndex === 0? a.id : a.name.toLowerCase();
    let valB = colIndex === 0? b.id : b.name.toLowerCase();
    return valA > valB? 1 : -1;
  });
  saveStudents();
  filterTable();
}

function viewProfile(id){
  let s = studentsData.find(st => st.id === id);
  let container = document.getElementById('profileContent');
  if(!s){
    container.innerHTML = '<div class="empty-state">Student not found.</div>';
  } else {
    let status = s.score >= 50 ? 'Pass' : 'Fail';
    let badgeClass = s.score >= 50 ? 'badge-pass' : 'badge-fail';
    let color = scoreColor(s.score);
    let initials = s.name.split(' ').map(n => n[0]).join('').substring(0,2).toUpperCase();
    container.innerHTML = `
      <div class="profile-card">
        <div class="profile-avatar">${initials}</div>
        <h3>${s.name}</h3>
        <div class="pid">Student ID: ${s.id}</div>
        <div class="profile-detail-row"><span>Subject</span><span>${s.subject}</span></div>
        <div class="profile-detail-row"><span>Score</span><span>${s.score}%</span></div>
        <div class="profile-detail-row"><span>Status</span><span>${status}</span></div>
        <div class="profile-bar-wrap">
          <div class="perf-bar-track"><div class="perf-bar-fill" id="profileBar" style="background:${color};"></div></div>
        </div>
        <span class="profile-status-badge ${badgeClass}">${status}</span><br>
        <button class="btn-outline" style="margin-top:1.5rem;" onclick="openPage('dashboard', {target:document.querySelector('.nav-links a')})">&larr; Back to Dashboard</button>
      </div>
    `;
    setTimeout(()=>{
      let bar = document.getElementById('profileBar');
      if(bar) bar.style.width = s.score + '%';
    }, 30);
  }

  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('profile').classList.add('active');
  document.querySelectorAll('.nav-links a').forEach(a=>a.classList.remove('active'));
  window.scrollTo(0,0);
  document.getElementById('navLinks').classList.remove('show');
}

loadData();
</script>
</body>
</html>
